// .env.example
DATABASE_URL="postgresql://user:pass@localhost:5432/bureaucracy_copilot"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-32-char-string"
ASI_ONE_API_KEY="your-asi-one-api-key"
ASI_ONE_BASE_URL="https://api.asi1.ai/v1"
ASI_ONE_MODEL="asi1"
UPLOADTHING_SECRET="your-uploadthing-secret"
UPLOADTHING_APP_ID="your-uploadthing-app-id"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-key"
SUPABASE_BUCKET="documents"
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
PII_ENCRYPTION_KEY="your-64-char-hex-string-32-bytes"
GOOGLE_CLIENT_ID="optional"
GOOGLE_CLIENT_SECRET="optional"
GITHUB_CLIENT_ID="optional"
GITHUB_CLIENT_SECRET="optional"

# Email (Gmail via Nodemailer)
# Use a Google App Password — NOT your real Gmail password.
# How to generate: Google Account -> Security -> 2-Step Verification -> App Passwords
SMTP_USER="yourname@gmail.com"
SMTP_PASSWORD="your-16-char-google-app-password"

# Cron Security — generate with: openssl rand -hex 32
CRON_SECRET="your-secure-random-32-char-string"
